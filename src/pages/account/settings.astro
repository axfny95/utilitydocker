---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';

if (!Astro.locals.user) {
  return Astro.redirect('/login?redirect=/account/settings');
}

const user = Astro.locals.user;
---

<BaseLayout title="Account Settings" description="Manage your UtilityDocker account settings.">
  <div class="mx-auto max-w-xl px-4 py-12 sm:px-6">
    <h1 class="text-2xl font-bold text-surface-900">Account Settings</h1>

    <div class="mt-8 space-y-6">
      <!-- Email -->
      <div class="rounded-xl border border-surface-200 bg-white p-5">
        <h2 class="text-sm font-semibold text-surface-700">Email Address</h2>
        <p class="mt-1 text-surface-900">{user.email}</p>
        <p class="mt-1 text-xs text-surface-400">
          {user.emailVerified ? 'Verified' : 'Not verified — check your email for verification link'}
        </p>
      </div>

      <!-- Account info -->
      <div class="rounded-xl border border-surface-200 bg-white p-5">
        <h2 class="text-sm font-semibold text-surface-700">Account</h2>
        <p class="mt-1 text-sm text-surface-600">
          Member since {new Date(user.createdAt * 1000).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
        <p class="mt-1 text-sm text-surface-600">
          Plan: <strong>{Astro.locals.isPremium ? 'Premium' : 'Free'}</strong>
          {!Astro.locals.isPremium && (
            <a href="/pricing" class="ml-2 text-primary-600 hover:underline">Upgrade</a>
          )}
        </p>
      </div>

      <!-- Danger zone -->
      <div class="rounded-xl border border-red-200 bg-red-50/50 p-5">
        <h2 class="text-sm font-semibold text-red-700">Danger Zone</h2>
        <p class="mt-1 text-xs text-red-600">Once deleted, your account cannot be recovered.</p>
        <button class="mt-3 rounded-lg border border-red-300 px-4 py-2 text-sm font-medium text-red-700 hover:bg-red-100" onclick="alert('Contact hello@utilitydocker.com to delete your account.')">
          Delete Account
        </button>
      </div>
    </div>

    <a href="/account" class="mt-6 inline-block text-sm text-primary-600 hover:underline">&larr; Back to Account</a>
  </div>
</BaseLayout>
