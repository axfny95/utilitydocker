---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { createSandboxHtml } from '../../lib/sandbox';

const { slug } = Astro.params;
const db = (await getCfEnv(Astro.locals)).DB;

const tool = await db
  .prepare('SELECT ct.*, u.email as creator_email FROM custom_tools ct JOIN users u ON ct.user_id = u.id WHERE ct.share_slug = ?')
  .bind(slug)
  .first();

if (!tool) {
  return Astro.redirect('/404');
}

// If private, only owner can view
if (!tool.is_public && (!Astro.locals.user || Astro.locals.user.id !== tool.user_id)) {
  return Astro.redirect('/404');
}

const isOwner = Astro.locals.user?.id === tool.user_id;
const sandboxHtml = createSandboxHtml(tool.generated_code as string);
const creatorName = (tool.creator_email as string).split('@')[0];
const createdDate = new Date((tool.created_at as number) * 1000).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${tool.title} - Community Tool`} description={tool.description as string || `Custom tool built by ${creatorName} on UtilityDocker`}>
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6">
    <!-- Header -->
    <div class="mb-6">
      <div class="flex items-center gap-2 text-sm text-surface-500">
        <a href="/community" class="hover:text-primary-600">&larr; Community Tools</a>
        <span>&middot;</span>
        <span>Built by {creatorName}</span>
        <span>&middot;</span>
        <span>{createdDate}</span>
        {tool.is_public ? (
          <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs text-green-700">Public</span>
        ) : (
          <span class="rounded-full bg-surface-100 px-2 py-0.5 text-xs text-surface-600">Private</span>
        )}
      </div>
      <h1 class="mt-2 text-2xl font-bold text-surface-900">{tool.title}</h1>
      {tool.description && <p class="mt-1 text-surface-600">{tool.description}</p>}
    </div>

    {/* Visibility toggle for owner */}
    {isOwner && (
      <div class="mb-4 flex items-center gap-3 rounded-lg border border-surface-200 bg-surface-50 px-4 py-3">
        <span class="text-sm text-surface-600">Visibility:</span>
        <button
          id="toggle-visibility"
          data-tool-id={tool.id}
          data-is-public={tool.is_public ? 'true' : 'false'}
          class="rounded-lg border border-surface-200 px-3 py-1.5 text-sm font-medium text-surface-700 hover:bg-white"
        >
          {tool.is_public ? 'Make Private' : 'Make Public'}
        </button>
        <button
          id="delete-tool"
          data-tool-id={tool.id}
          class="rounded-lg border border-red-200 px-3 py-1.5 text-sm font-medium text-red-600 hover:bg-red-50"
        >
          Delete Tool
        </button>
      </div>
    )}

    <!-- Tool sandbox -->
    <div class="overflow-hidden rounded-xl border border-surface-200">
      <iframe
        sandbox="allow-scripts"
        srcdoc={sandboxHtml}
        class="w-full border-0"
        style="min-height: 400px;"
        title={tool.title as string}
        id="tool-iframe"
      />
    </div>

    <div class="mt-4 rounded-lg border border-surface-200 bg-surface-50 px-4 py-3 text-xs text-surface-400">
      This tool was generated by an AI and runs in a sandboxed environment. It cannot access your data, cookies, or other pages. Use at your own discretion.
    </div>

    <!-- CTA -->
    <div class="mt-8 rounded-xl border border-primary-200 bg-primary-50 p-6 text-center">
      <p class="text-sm text-surface-600">Want to build your own custom tools?</p>
      <a href="/pricing" class="mt-2 inline-block rounded-lg bg-primary-600 px-6 py-2 text-sm font-medium text-white hover:bg-primary-700">
        Try the AI Tool Builder — $7/mo
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  // Auto-resize iframe
  window.addEventListener('message', (e) => {
    if (e.data?.type === 'resize') {
      const iframe = document.getElementById('tool-iframe') as HTMLIFrameElement;
      if (iframe) iframe.style.height = Math.min(e.data.height + 32, 800) + 'px';
    }
  });

  // Visibility toggle
  document.getElementById('toggle-visibility')?.addEventListener('click', async (e) => {
    const btn = e.target as HTMLButtonElement;
    const toolId = btn.dataset.toolId;
    const isCurrentlyPublic = btn.dataset.isPublic === 'true';
    btn.textContent = 'Updating...';
    btn.disabled = true;
    try {
      await fetch(`/api/tool-builder/${toolId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ isPublic: !isCurrentlyPublic }),
      });
      window.location.reload();
    } catch { btn.textContent = 'Error'; btn.disabled = false; }
  });

  // Delete tool
  document.getElementById('delete-tool')?.addEventListener('click', async (e) => {
    if (!confirm('Delete this tool permanently?')) return;
    const btn = e.target as HTMLButtonElement;
    const toolId = btn.dataset.toolId;
    try {
      await fetch(`/api/tool-builder/${toolId}`, { method: 'DELETE' });
      window.location.href = '/account';
    } catch { alert('Failed to delete'); }
  });
</script>
