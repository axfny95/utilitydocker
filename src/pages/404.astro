---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/shared/ToolCard.astro';
import { getCollection } from 'astro:content';

const tools = await getCollection('tools');
const featured = tools.filter((t) => t.data.featured).slice(0, 3);
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="mx-auto max-w-3xl px-4 py-20 text-center">
    <p class="text-6xl font-bold text-primary-600">404</p>
    <h1 class="mt-4 text-2xl font-bold text-surface-900">Page Not Found</h1>
    <p class="mt-2 text-surface-600">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/" class="rounded-lg bg-primary-600 px-5 py-2 text-sm font-medium text-white hover:bg-primary-700">
        Go Home
      </a>
      <a href="/tools" class="rounded-lg border border-surface-200 px-5 py-2 text-sm font-medium text-surface-700 hover:bg-surface-50">
        Browse Tools
      </a>
    </div>

    {featured.length > 0 && (
      <div class="mt-12">
        <h2 class="mb-4 text-lg font-semibold text-surface-900">Popular Tools</h2>
        <div class="grid gap-4 sm:grid-cols-3">
          {featured.map((tool) => (
            <ToolCard
              title={tool.data.title}
              description={tool.data.description}
              slug={tool.id}
              category={tool.data.category}
            />
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>
