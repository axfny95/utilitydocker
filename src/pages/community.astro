---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Community Tools" description="Browse custom tools built by UtilityDocker users. Discover unique utilities created with our AI Tool Builder.">
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-surface-900">Community Tools</h1>
      <p class="mt-2 text-lg text-surface-600">
        Custom tools built by UtilityDocker users with the AI Tool Builder. All tools run in your browser.
      </p>
    </div>

    <div id="tools-grid" class="grid gap-4 sm:grid-cols-2">
      <!-- Populated by JS -->
    </div>

    <div id="loading" class="py-12 text-center text-surface-500">Loading community tools...</div>
    <div id="empty" class="hidden py-12 text-center">
      <p class="text-surface-500">No community tools yet.</p>
      <a href="/pricing" class="mt-2 inline-block text-sm font-medium text-primary-600 hover:underline">Be the first — build one with the AI Tool Builder</a>
    </div>
  </div>
</BaseLayout>

<script>
  async function loadTools() {
    const grid = document.getElementById('tools-grid')!;
    const loading = document.getElementById('loading')!;
    const empty = document.getElementById('empty')!;

    try {
      const res = await fetch('/api/tool-builder/public');
      const data = await res.json();

      loading.classList.add('hidden');

      if (!data.tools || data.tools.length === 0) {
        empty.classList.remove('hidden');
        return;
      }

      grid.innerHTML = data.tools.map((tool: any) => `
        <a href="/community/${tool.share_slug}" class="group rounded-xl border border-surface-200 bg-white p-5 transition-all hover:shadow-md">
          <h3 class="font-semibold text-surface-900 group-hover:text-primary-600">${tool.title}</h3>
          <p class="mt-1 text-sm text-surface-500 line-clamp-2">${tool.description || ''}</p>
          <div class="mt-3 flex items-center justify-between text-xs text-surface-400">
            <span>by ${tool.creator_email?.split('@')[0] || 'anonymous'}</span>
            <span>${new Date(tool.created_at * 1000).toLocaleDateString()}</span>
          </div>
        </a>
      `).join('');
    } catch {
      loading.textContent = 'Failed to load tools.';
    }
  }

  loadTools();
</script>
