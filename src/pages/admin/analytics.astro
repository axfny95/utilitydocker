---
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getCfEnv } from "../../lib/cf-env";

const adminPassword = (await getCfEnv(Astro.locals)).ADMIN_PASSWORD;
const authHeader = Astro.request.headers.get('authorization');
const isAdmin = Astro.locals.user || (adminPassword && authHeader === `Bearer ${adminPassword}`);
if (!isAdmin) {
  return new Response('Unauthorized', { status: 401, headers: { 'WWW-Authenticate': 'Bearer' } });
}
---

<AdminLayout title="Analytics">
  <div class="rounded-xl border border-surface-200 bg-white p-8 text-center">
    <p class="text-surface-500">Analytics integration coming soon.</p>
    <p class="mt-2 text-sm text-surface-400">
      This will connect to Cloudflare Analytics Engine and Google Analytics 4
      to show tool-level usage metrics.
    </p>
  </div>
</AdminLayout>
