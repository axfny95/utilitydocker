---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Payment Successful" description="Your premium subscription is now active.">
  <div class="mx-auto max-w-md px-4 py-20 text-center">
    <svg class="mx-auto h-16 w-16 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <h1 class="mt-4 text-2xl font-bold text-surface-900">Welcome to Premium!</h1>
    <p class="mt-2 text-surface-600">Your subscription is now active. Enjoy ad-free tools and the AI Tool Builder.</p>
    <div class="mt-6 flex flex-col gap-3">
      <a href="/tool-builder" class="rounded-lg bg-primary-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-primary-700">
        Try the AI Tool Builder
      </a>
      <a href="/account" class="rounded-lg border border-surface-200 px-6 py-2.5 text-sm font-medium text-surface-700 hover:bg-surface-50">
        Go to Account
      </a>
    </div>
  </div>
</BaseLayout>
