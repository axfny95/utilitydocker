---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

let posts: Awaited<ReturnType<typeof getCollection<'blog'>>> = [];
try {
  posts = await getCollection('blog');
} catch {
  // Collection may be empty
}
const sortedPosts = posts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout title="Blog" description="Tips, guides, and tutorials about using free online tools effectively.">
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Blog</h1>
    <p class="mt-2 text-lg text-surface-600">Tips, guides, and tutorials.</p>

    {sortedPosts.length === 0 && (
      <p class="mt-8 text-surface-500">No posts yet. Check back soon!</p>
    )}

    <div class="mt-8 space-y-8">
      {sortedPosts.map((post) => (
        <article class="group">
          <a href={`/blog/${post.id}`} class="block">
            <h2 class="text-xl font-semibold text-surface-900 group-hover:text-primary-600">{post.data.title}</h2>
            <p class="mt-1 text-surface-600">{post.data.description}</p>
            <time class="mt-2 block text-sm text-surface-400" datetime={post.data.publishedAt.toISOString()}>
              {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
