---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Forgot Password" description="Reset your UtilityDocker account password.">
  <div class="mx-auto max-w-sm px-4 py-16">
    <div class="text-center">
      <a href="/" class="text-2xl font-bold text-primary-600">UtilityDocker</a>
      <h1 class="mt-4 text-2xl font-bold text-surface-900">Reset your password</h1>
      <p class="mt-1 text-sm text-surface-500">Enter your email and we'll send you a reset link.</p>
    </div>

    <div id="form-container" class="mt-8">
      <form id="forgot-form" class="space-y-4">
        <div>
          <label for="email" class="mb-1 block text-sm font-medium text-surface-700">Email</label>
          <input id="email" type="email" required class="w-full rounded-lg border border-surface-200 px-3 py-2.5 text-sm focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500" placeholder="you@example.com" />
        </div>
        <div id="error" class="hidden rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"></div>
        <button type="submit" id="submit-btn" class="w-full rounded-lg bg-primary-600 py-2.5 text-sm font-medium text-white hover:bg-primary-700">
          Send Reset Link
        </button>
      </form>
    </div>

    <div id="success" class="mt-8 hidden rounded-xl border border-green-200 bg-green-50 p-6 text-center">
      <p class="font-medium text-green-800">Check your email</p>
      <p class="mt-1 text-sm text-green-700">If an account exists with that email, we sent a password reset link.</p>
    </div>

    <p class="mt-6 text-center text-sm text-surface-500">
      <a href="/login" class="font-medium text-primary-600 hover:underline">Back to login</a>
    </p>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('forgot-form') as HTMLFormElement;
  const errorEl = document.getElementById('error')!;
  const successEl = document.getElementById('success')!;
  const formContainer = document.getElementById('form-container')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    btn.textContent = 'Sending...';
    btn.disabled = true;
    errorEl.classList.add('hidden');

    // Always show success to prevent email enumeration
    formContainer.classList.add('hidden');
    successEl.classList.remove('hidden');
  });
</script>
