---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Offline" description="You are currently offline.">
  <div class="mx-auto max-w-md px-4 py-20 text-center">
    <svg class="mx-auto h-16 w-16 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636a9 9 0 010 12.728m0 0l-2.829-2.829m2.829 2.829L21 21M15.536 8.464a5 5 0 010 7.072m0 0l-2.829-2.829m-4.243 2.829a4.978 4.978 0 01-1.414-2.83m-1.414 5.658a9 9 0 01-2.167-9.238m7.824 2.167a1 1 0 111.414 1.414m-1.414-1.414L3 3" />
    </svg>
    <h1 class="mt-6 text-2xl font-bold text-surface-900">You're Offline</h1>
    <p class="mt-2 text-surface-600">
      Check your internet connection and try again. Tools you've visited before may still work offline.
    </p>
    <button onclick="window.location.reload()" class="mt-6 rounded-lg bg-primary-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-primary-700">
      Try Again
    </button>
  </div>
</BaseLayout>
