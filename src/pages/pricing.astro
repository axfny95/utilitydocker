---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pricing - FreeToolStack Premium" description="Upgrade to FreeToolStack Premium for ad-free experience, higher limits, and exclusive tools.">
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <div class="text-center">
      <h1 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Simple, Transparent Pricing</h1>
      <p class="mt-4 text-lg text-surface-600">All core tools are free forever. Premium unlocks extra features.</p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2">
      <!-- Free tier -->
      <div class="rounded-2xl border border-surface-200 bg-white p-8">
        <h2 class="text-xl font-bold text-surface-900">Free</h2>
        <p class="mt-1 text-surface-500">Everything you need to get started</p>
        <p class="mt-6 text-4xl font-bold text-surface-900">$0<span class="text-lg font-normal text-surface-500">/mo</span></p>
        <ul class="mt-8 space-y-3 text-sm text-surface-600">
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            All core tools
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Client-side processing
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            No signup required
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            Ads displayed
          </li>
        </ul>
        <a href="/tools" class="mt-8 block rounded-xl border border-surface-300 py-3 text-center font-medium text-surface-700 transition-colors hover:bg-surface-50">
          Get Started Free
        </a>
      </div>

      <!-- Premium tier -->
      <div class="rounded-2xl border-2 border-primary-500 bg-white p-8 shadow-lg">
        <div class="flex items-center gap-2">
          <h2 class="text-xl font-bold text-surface-900">Premium</h2>
          <span class="rounded-full bg-primary-100 px-2 py-0.5 text-xs font-medium text-primary-700">Popular</span>
        </div>
        <p class="mt-1 text-surface-500">For power users who want more</p>
        <p class="mt-6 text-4xl font-bold text-surface-900">$5<span class="text-lg font-normal text-surface-500">/mo</span></p>
        <p class="text-sm text-surface-500">or $39/year (save 35%)</p>
        <ul class="mt-8 space-y-3 text-sm text-surface-600">
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Everything in Free
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Ad-free experience
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Higher file size limits
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Batch processing
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Premium-only tools
          </li>
        </ul>
        <button class="mt-8 block w-full rounded-xl bg-primary-600 py-3 text-center font-medium text-white transition-colors hover:bg-primary-700">
          Coming Soon
        </button>
      </div>
    </div>
  </div>
</BaseLayout>
