---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';

const user = Astro.locals?.user;
const isPremium = Astro.locals?.isPremium;
// TODO: Check specific plan (premium vs premium_plus) from subscription table
const currentPlan = isPremium ? 'premium' : 'free';
---

<BaseLayout title="Pricing - UtilityDocker" description="Choose your plan. Free tools forever, or upgrade to Premium ($5/mo) or Premium Plus ($7/mo) for ad-free and AI features.">
  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <div class="text-center">
      <h1 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Choose Your Plan</h1>
      <p class="mt-4 text-lg text-surface-600">All 73 tools are free forever. Upgrade for an ad-free experience or to build your own tools.</p>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      <!-- Free -->
      <div class="rounded-2xl border border-surface-200 bg-white p-7">
        <h2 class="text-xl font-bold text-surface-900">Free</h2>
        <p class="mt-1 text-sm text-surface-500">For everyone</p>
        <p class="mt-5 text-4xl font-bold text-surface-900">$0<span class="text-lg font-normal text-surface-500">/mo</span></p>
        <ul class="mt-6 space-y-2.5 text-sm text-surface-600">
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            All 73 tools, unlimited use
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Client-side processing
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Save favorites (with account)
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            <span class="text-surface-400">Ads displayed</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            <span class="text-surface-400">No AI Tool Builder</span>
          </li>
        </ul>
        {!user ? (
          <a href="/signup" class="mt-7 block rounded-xl border border-surface-300 py-2.5 text-center text-sm font-medium text-surface-700 hover:bg-surface-50">
            Create Free Account
          </a>
        ) : (
          <div class="mt-7 rounded-xl border border-green-200 bg-green-50 py-2.5 text-center text-sm font-medium text-green-700">
            {currentPlan === 'free' ? 'Current Plan' : 'Included'}
          </div>
        )}
      </div>

      <!-- Premium $5/mo -->
      <div class="rounded-2xl border border-surface-200 bg-white p-7">
        <h2 class="text-xl font-bold text-surface-900">Premium</h2>
        <p class="mt-1 text-sm text-surface-500">Ad-free experience</p>
        <p class="mt-5 text-4xl font-bold text-surface-900">$5<span class="text-lg font-normal text-surface-500">/mo</span></p>
        <p class="text-xs text-surface-400">Cancel anytime</p>
        <ul class="mt-6 space-y-2.5 text-sm text-surface-600">
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Everything in Free
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <strong>Completely ad-free</strong>
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Priority support
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            <span class="text-surface-400">No AI Tool Builder</span>
          </li>
        </ul>
        {user ? (
          <button data-plan="premium" class="checkout-btn mt-7 block w-full rounded-xl border-2 border-primary-500 py-2.5 text-center text-sm font-medium text-primary-700 hover:bg-primary-50">
            {isPremium ? 'Current Plan' : 'Subscribe — $5/mo'}
          </button>
        ) : (
          <a href="/signup?redirect=/pricing" class="mt-7 block rounded-xl border-2 border-primary-500 py-2.5 text-center text-sm font-medium text-primary-700 hover:bg-primary-50">
            Sign Up to Subscribe
          </a>
        )}
      </div>

      <!-- Premium Plus $7/mo -->
      <div class="rounded-2xl border-2 border-primary-500 bg-white p-7 shadow-lg ring-1 ring-primary-100">
        <div class="flex items-center gap-2">
          <h2 class="text-xl font-bold text-surface-900">Premium Plus</h2>
          <span class="rounded-full bg-primary-100 px-2 py-0.5 text-xs font-medium text-primary-700">Best Value</span>
        </div>
        <p class="mt-1 text-sm text-surface-500">Build your own tools</p>
        <p class="mt-5 text-4xl font-bold text-surface-900">$7<span class="text-lg font-normal text-surface-500">/mo</span></p>
        <p class="text-xs text-surface-400">Cancel anytime &middot; Upgrade from Premium for just $2</p>
        <ul class="mt-6 space-y-2.5 text-sm text-surface-600">
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Everything in Premium
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <strong>AI Tool Builder</strong> — describe any tool, we build it
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            20 AI tool generations per month
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Publish tools to Community
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Save & manage custom tools
          </li>
        </ul>
        {user ? (
          <button data-plan="premium_plus" class="checkout-btn mt-7 block w-full rounded-xl bg-primary-600 py-2.5 text-center text-sm font-medium text-white hover:bg-primary-700">
            Subscribe — $7/mo
          </button>
        ) : (
          <a href="/signup?redirect=/pricing" class="mt-7 block rounded-xl bg-primary-600 py-2.5 text-center text-sm font-medium text-white hover:bg-primary-700">
            Sign Up to Subscribe
          </a>
        )}
      </div>
    </div>

    <p class="mt-8 text-center text-sm text-surface-400">
      Cancel anytime. Upgrade or downgrade between plans instantly — we prorate the difference.
    </p>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.checkout-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const plan = (btn as HTMLButtonElement).dataset.plan;
      btn.textContent = 'Redirecting to checkout...';
      (btn as HTMLButtonElement).disabled = true;
      try {
        const res = await fetch('/api/stripe/create-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan }),
        });
        const data = await res.json();
        if (data.url) window.location.href = data.url;
        else { btn.textContent = 'Error — try again'; (btn as HTMLButtonElement).disabled = false; }
      } catch {
        btn.textContent = 'Error — try again';
        (btn as HTMLButtonElement).disabled = false;
      }
    });
  });
</script>
