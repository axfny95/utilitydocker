---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';

const user = Astro.locals?.user;
const isPremium = Astro.locals?.isPremium;
---

<BaseLayout title="Pricing - UtilityDocker Premium" description="Upgrade to UtilityDocker Premium for $7/month. Ad-free tools, AI Tool Builder, and favorites.">
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <div class="text-center">
      <h1 class="text-3xl font-bold tracking-tight text-surface-900 sm:text-4xl">Simple, Transparent Pricing</h1>
      <p class="mt-4 text-lg text-surface-600">All 59 tools are free forever. Premium unlocks the AI Tool Builder and removes ads.</p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2">
      <!-- Free tier -->
      <div class="rounded-2xl border border-surface-200 bg-white p-8">
        <h2 class="text-xl font-bold text-surface-900">Free</h2>
        <p class="mt-1 text-surface-500">Everything you need</p>
        <p class="mt-6 text-4xl font-bold text-surface-900">$0<span class="text-lg font-normal text-surface-500">/mo</span></p>
        <ul class="mt-8 space-y-3 text-sm text-surface-600">
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            All 59 tools, unlimited use
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Client-side processing (privacy)
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Save favorite tools (with account)
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            Ads displayed
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-surface-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            No AI Tool Builder
          </li>
        </ul>
        {user ? (
          <div class="mt-8 rounded-xl border border-green-200 bg-green-50 py-3 text-center text-sm font-medium text-green-700">
            Current Plan
          </div>
        ) : (
          <a href="/signup" class="mt-8 block rounded-xl border border-surface-300 py-3 text-center font-medium text-surface-700 transition-colors hover:bg-surface-50">
            Create Free Account
          </a>
        )}
      </div>

      <!-- Premium tier -->
      <div class="rounded-2xl border-2 border-primary-500 bg-white p-8 shadow-lg">
        <div class="flex items-center gap-2">
          <h2 class="text-xl font-bold text-surface-900">Premium</h2>
          <span class="rounded-full bg-primary-100 px-2 py-0.5 text-xs font-medium text-primary-700">Best Value</span>
        </div>
        <p class="mt-1 text-surface-500">For power users and creators</p>
        <p class="mt-6 text-4xl font-bold text-surface-900">$7<span class="text-lg font-normal text-surface-500">/mo</span></p>
        <p class="text-sm text-surface-500">Cancel anytime</p>
        <ul class="mt-8 space-y-3 text-sm text-surface-600">
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Everything in Free
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <strong>AI Tool Builder</strong> — describe any tool, we build it
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            20 AI tool generations per month
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Completely ad-free experience
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Save & share custom tools
          </li>
        </ul>
        {isPremium ? (
          <div class="mt-8 rounded-xl border border-green-200 bg-green-50 py-3 text-center text-sm font-medium text-green-700">
            Active — <a href="/account/billing" class="underline">Manage</a>
          </div>
        ) : user ? (
          <button
            id="checkout-btn"
            class="mt-8 block w-full rounded-xl bg-primary-600 py-3 text-center font-medium text-white transition-colors hover:bg-primary-700"
          >
            Subscribe — $7/month
          </button>
        ) : (
          <a href="/signup?redirect=/pricing" class="mt-8 block rounded-xl bg-primary-600 py-3 text-center font-medium text-white transition-colors hover:bg-primary-700">
            Create Account to Subscribe
          </a>
        )}
      </div>
    </div>

    <p class="mt-8 text-center text-sm text-surface-400">
      Cancel anytime from your account settings. No long-term commitment.
    </p>
  </div>
</BaseLayout>

<script>
  const btn = document.getElementById('checkout-btn');
  btn?.addEventListener('click', async () => {
    btn.textContent = 'Redirecting to checkout...';
    btn.setAttribute('disabled', 'true');
    try {
      const res = await fetch('/api/stripe/create-checkout', { method: 'POST' });
      const data = await res.json();
      if (data.url) window.location.href = data.url;
      else { btn.textContent = 'Error — try again'; btn.removeAttribute('disabled'); }
    } catch {
      btn.textContent = 'Error — try again';
      btn.removeAttribute('disabled');
    }
  });
</script>
