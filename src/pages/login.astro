---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import LoginForm from '../components/auth/LoginForm';

// Redirect if already logged in
if (Astro.locals.user) {
  return Astro.redirect('/account');
}
---

<BaseLayout title="Sign In" description="Sign in to your UtilityDocker account to access favorites and premium features.">
  <div class="mx-auto max-w-sm px-4 py-16">
    <div class="text-center">
      <a href="/" class="text-2xl font-bold text-primary-600">UtilityDocker</a>
      <h1 class="mt-4 text-2xl font-bold text-surface-900">Welcome back</h1>
      <p class="mt-1 text-sm text-surface-500">Sign in to your account</p>
    </div>
    <div class="mt-8">
      <LoginForm client:load />
    </div>
  </div>
</BaseLayout>
