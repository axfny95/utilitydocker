---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';

const token = Astro.url.searchParams.get('token');
let verified = false;
let error = '';

if (token) {
  try {
    const res = await fetch(`${Astro.url.origin}/api/auth/verify-email?token=${token}`);
    const data = await res.json();
    verified = data.ok === true;
    if (!verified) error = data.error || 'Verification failed';
  } catch {
    error = 'Something went wrong';
  }
} else {
  error = 'Missing verification token';
}
---

<BaseLayout title="Verify Email" description="Verify your UtilityDocker email address.">
  <div class="mx-auto max-w-sm px-4 py-16 text-center">
    {verified ? (
      <>
        <svg class="mx-auto h-16 w-16 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h1 class="mt-4 text-2xl font-bold text-surface-900">Email Verified!</h1>
        <p class="mt-2 text-surface-600">Your email has been verified. You can now sign in.</p>
        <a href="/login" class="mt-6 inline-block rounded-lg bg-primary-600 px-6 py-2.5 text-sm font-medium text-white hover:bg-primary-700">
          Sign In
        </a>
      </>
    ) : (
      <>
        <svg class="mx-auto h-16 w-16 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <h1 class="mt-4 text-2xl font-bold text-surface-900">Verification Failed</h1>
        <p class="mt-2 text-surface-600">{error}</p>
        <a href="/signup" class="mt-6 inline-block rounded-lg border border-surface-200 px-6 py-2.5 text-sm font-medium text-surface-700 hover:bg-surface-50">
          Try Again
        </a>
      </>
    )}
  </div>
</BaseLayout>
