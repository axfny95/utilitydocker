---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} - Admin</title>
  </head>
  <body class="min-h-screen bg-surface-50">
    <header class="border-b border-surface-200 bg-white">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6">
        <div class="flex items-center gap-4">
          <a href="/" class="text-lg font-bold text-primary-600">UtilityDocker</a>
          <span class="rounded bg-surface-100 px-2 py-0.5 text-xs font-medium text-surface-600">Admin</span>
        </div>
        <nav class="flex gap-4 text-sm">
          <a href="/admin" class="text-surface-600 hover:text-primary-600">Dashboard</a>
          <a href="/admin/analytics" class="text-surface-600 hover:text-primary-600">Analytics</a>
          <a href="/" class="text-surface-600 hover:text-primary-600">View Site</a>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
      <h1 class="mb-6 text-2xl font-bold text-surface-900">{title}</h1>
      <slot />
    </main>
  </body>
</html>
