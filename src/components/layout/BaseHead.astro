---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/og-default.svg',
  type = 'website',
} = Astro.props;

const siteName = 'UtilityDocker';
const fullTitle = title === siteName ? title : `${title} - ${siteName}`;
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
const adsenseClientId = import.meta.env.ADSENSE_CLIENT_ID;
---

<meta charset="utf-8" />
<meta name="adsense-client" content="ca-pub-1657915040878664" />
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1657915040878664" crossorigin="anonymous"></script>
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
<meta name="author" content="UtilityDocker" />
<meta name="publisher" content="UtilityDocker" />
<link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />
<link rel="dns-prefetch" href="https://www.googletagmanager.com" />

<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:site_name" content={siteName} />
<meta property="og:image" content={new URL(ogImage, Astro.site).href} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="manifest" href="/manifest.json" />
<meta name="theme-color" content="#2563eb" />
<link rel="apple-touch-icon" href="/icon-192.svg" />

{/* Service Worker registration */}
<script>
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  }
</script>

{/* Google Analytics 4 — only loads when PUBLIC_GA4_ID is set */}
{ga4Id && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
    <script define:vars={{ ga4Id }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', ga4Id, { anonymize_ip: true });
    </script>
  </>
)}

<slot />
