---
interface Props {
  user?: { id: string; email: string } | null;
  isPremium?: boolean;
}

const { user = null, isPremium = false } = Astro.props;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Tools', href: '/tools' },
  { label: 'Community', href: '/community' },
  { label: 'Blog', href: '/blog' },
  { label: 'Pricing', href: '/pricing' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-surface-200 bg-white/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-2 text-xl font-bold text-primary-600">
      <svg class="h-8 w-8" viewBox="0 0 32 32" fill="none">
        <rect width="32" height="32" rx="8" fill="currentColor" />
        <path d="M8 16h16M16 8v16" stroke="white" stroke-width="2.5" stroke-linecap="round" />
      </svg>
      UtilityDocker
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
            currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
              ? 'bg-primary-50 text-primary-700'
              : 'text-surface-600 hover:bg-surface-100 hover:text-surface-900',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      {user ? (
        <>
          {isPremium && (
            <span class="hidden rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-800 sm:inline-flex">
              Premium
            </span>
          )}
          <a
            href="/account"
            class="flex items-center gap-2 rounded-lg border border-surface-200 px-3 py-2 text-sm font-medium text-surface-700 transition-colors hover:bg-surface-50"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span class="hidden sm:inline">Account</span>
          </a>
        </>
      ) : (
        <>
          <a
            href="/login"
            class="hidden rounded-lg px-3 py-2 text-sm font-medium text-surface-600 transition-colors hover:bg-surface-100 sm:inline-flex"
          >
            Sign In
          </a>
          <a
            href="/signup"
            class="rounded-lg bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-700"
          >
            Get Started Free
          </a>
        </>
      )}

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="rounded-lg p-2 text-surface-600 hover:bg-surface-100 md:hidden"
        aria-label="Open menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-surface-200 bg-white md:hidden">
    <nav class="flex flex-col px-4 py-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-lg px-3 py-2 text-sm font-medium',
            currentPath === item.href
              ? 'bg-primary-50 text-primary-700'
              : 'text-surface-600 hover:bg-surface-100',
          ]}
        >
          {item.label}
        </a>
      ))}
      {!user && (
        <>
          <a href="/login" class="rounded-lg px-3 py-2 text-sm font-medium text-surface-600 hover:bg-surface-100">Sign In</a>
          <a href="/signup" class="rounded-lg px-3 py-2 text-sm font-medium text-primary-600 hover:bg-primary-50">Create Account</a>
        </>
      )}
      {user && (
        <a href="/account" class="rounded-lg px-3 py-2 text-sm font-medium text-surface-600 hover:bg-surface-100">My Account</a>
      )}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
