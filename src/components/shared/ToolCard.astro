---
interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  icon?: string;
  featured?: boolean;
}

const { title, description, slug, category, featured } = Astro.props;
---

<a
  href={`/tools/${slug}`}
  class:list={[
    'group block rounded-xl border bg-white p-5 transition-all hover:shadow-md',
    featured ? 'border-primary-200 ring-1 ring-primary-100' : 'border-surface-200',
  ]}
>
  <div class="mb-3 flex items-center justify-between">
    <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary-600">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.88 3.41a1 1 0 01-1.45-1.05l1.12-6.53-4.74-4.63a1 1 0 01.55-1.7l6.55-.95 2.93-5.94a1 1 0 011.8 0l2.93 5.94 6.55.95a1 1 0 01.55 1.7l-4.74 4.63 1.12 6.53a1 1 0 01-1.45 1.05l-5.88-3.41z" />
      </svg>
    </div>
    <span class="rounded-full bg-surface-100 px-2.5 py-0.5 text-xs font-medium text-surface-600">
      {category}
    </span>
  </div>
  <h3 class="font-semibold text-surface-900 group-hover:text-primary-600">{title}</h3>
  <p class="mt-1 text-sm text-surface-500 line-clamp-2">{description}</p>
</a>
