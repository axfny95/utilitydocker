---
import { getToolIconPath } from '../../lib/tool-icons';

interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  icon?: string;
  featured?: boolean;
}

const { title, description, slug, category, featured } = Astro.props;
const iconPath = getToolIconPath(slug, category);
---

<div class="group relative block rounded-xl border bg-white p-5 transition-all hover:shadow-md {featured ? 'border-primary-200 ring-1 ring-primary-100' : 'border-surface-200'}">
  <a href={`/tools/${slug}`} class="block">
    <div class="mb-3 flex items-center justify-between">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary-600">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d={iconPath} />
        </svg>
      </div>
      <span class="rounded-full bg-surface-100 px-2.5 py-0.5 text-xs font-medium text-surface-600">
        {category}
      </span>
    </div>
    <h3 class="font-semibold text-surface-900 group-hover:text-primary-600">{title}</h3>
    <p class="mt-1 text-sm text-surface-500 line-clamp-2">{description}</p>
  </a>

  <!-- Star/Save button — only visible for logged-in users (handled client-side) -->
  <button
    class="star-btn absolute right-3 top-3 hidden rounded-full p-1.5 text-surface-300 transition-colors hover:bg-amber-50 hover:text-amber-400"
    data-tool-slug={slug}
    title="Save to favorites"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
    </svg>
  </button>
</div>

<script>
  // Show star buttons only if user is logged in
  // Check auth state once and show/hide all star buttons
  async function initStarButtons() {
    try {
      const res = await fetch('/api/auth/me');
      const data = await res.json();
      if (!data.user) return; // Not logged in — stars stay hidden

      // Show all star buttons
      document.querySelectorAll('.star-btn').forEach((btn) => {
        (btn as HTMLElement).classList.remove('hidden');
      });

      // Load user's favorites
      const favRes = await fetch('/api/favorites');
      const favData = await favRes.json();
      const favorites = new Set(favData.favorites || []);

      // Mark starred tools
      document.querySelectorAll('.star-btn').forEach((btn) => {
        const slug = (btn as HTMLElement).dataset.toolSlug;
        if (slug && favorites.has(slug)) {
          btn.querySelector('svg')!.setAttribute('fill', '#fbbf24');
          btn.querySelector('svg')!.setAttribute('stroke', '#fbbf24');
          (btn as HTMLElement).classList.add('text-amber-400');
          (btn as HTMLElement).classList.remove('text-surface-300');
        }
      });

      // Add click handlers
      document.querySelectorAll('.star-btn').forEach((btn) => {
        btn.addEventListener('click', async (e) => {
          e.preventDefault();
          e.stopPropagation();
          const slug = (btn as HTMLElement).dataset.toolSlug;
          if (!slug) return;

          const isStarred = favorites.has(slug);
          if (isStarred) {
            await fetch(`/api/favorites/${slug}`, { method: 'DELETE' });
            favorites.delete(slug);
            btn.querySelector('svg')!.setAttribute('fill', 'none');
            btn.querySelector('svg')!.setAttribute('stroke', 'currentColor');
            (btn as HTMLElement).classList.remove('text-amber-400');
            (btn as HTMLElement).classList.add('text-surface-300');
          } else {
            await fetch('/api/favorites', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ toolSlug: slug }),
            });
            favorites.add(slug);
            btn.querySelector('svg')!.setAttribute('fill', '#fbbf24');
            btn.querySelector('svg')!.setAttribute('stroke', '#fbbf24');
            (btn as HTMLElement).classList.add('text-amber-400');
            (btn as HTMLElement).classList.remove('text-surface-300');
          }
        });
      });
    } catch {
      // Auth check failed — stars stay hidden
    }
  }

  // Run once on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStarButtons);
  } else {
    initStarButtons();
  }
</script>
